# ─────────────────────────────────────────────────────────────
#  Ethara Seat Allocation & Project Mapping System
#  Environment Variables — copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
SECRET_KEY=change-me-to-a-long-random-string

# ── PostgreSQL (Docker Compose) ──────────────────────────────
POSTGRES_USER=ethara
POSTGRES_PASSWORD=ethara_password
POSTGRES_DB=ethara_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Database URL (used by SQLAlchemy + Alembic) ───────────────
# async driver for the app:
DATABASE_URL=postgresql+asyncpg://ethara:ethara_password@localhost:5432/ethara_db
# sync driver for Alembic migrations:
SYNC_DATABASE_URL=postgresql+psycopg2://ethara:ethara_password@localhost:5432/ethara_db

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── AI Assistant (optional / stretch) ────────────────────────
# Uncomment and set if you want LLM-backed intent classification
# GEMINI_API_KEY=
# OPENAI_API_KEY=
